{
  "id": "mcp-control",
  "version": 1,
  "category": "behavior",
  "input": "这个线上偶发问题帮我查一下，日志很多，你自己看。",
  "primary_refs": [
    "references/mcp_control.md",
    "references/observability_logging.md"
  ],
  "output_contract": "free",
  "expected_hits": [
    {
      "key": "compress-to-fact-and-gap",
      "desc": "先缩成现象、已知事实、关键缺口",
      "anchor": "references/mcp_control.md"
    },
    {
      "key": "single-direction-progress",
      "desc": "工具调用围绕 1 个主方向推进",
      "anchor": "SKILL.md:11",
      "rule_id": "IR-003"
    },
    {
      "key": "switch-after-two-empty-tries",
      "desc": "两次无新增证据后主动切方向或收敛",
      "anchor": "references/mcp_control.md"
    }
  ],
  "failure_signals": [
    {
      "key": "shotgun-search",
      "desc": "一次性打开大量文件或大量搜索"
    },
    {
      "key": "no-budget-awareness",
      "desc": "没有预算意识"
    },
    {
      "key": "repeat-same-direction",
      "desc": "同一方向重复尝试"
    }
  ],
  "scoring": {
    "pass": "所有 expected_hits 命中且无 failure_signals 触发",
    "partial": "至少半数 expected_hits 命中且未触发任何核心 failure_signals",
    "fail": "命中任一 failure_signals 或 expected_hits 命中不到一半"
  }
}
